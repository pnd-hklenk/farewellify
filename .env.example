# Supabase Configuration
# Get these from your NEW Supabase project: Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=your_anon_public_key_here

# Email Configuration (for sending invitations and reminders)
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=no-reply@pandata.de
SMTP_PASSWORD=your_smtp_password_here
FLASK_SECRET_KEY=generate_a_new_secret_key_here

MIRO_ACCESS_TOKEN=your_miro_token_here
MIRO_TEAM_ID=your_miro_team_id_here
