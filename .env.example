# ===========================================
# FAREWELLIFY CONFIGURATION
# ===========================================
# Copy this file to .env and fill in the values

# -------------------------------------------
# SUPABASE (Required)
# -------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# -------------------------------------------
# FLASK (Required)
# -------------------------------------------
# Any random string for session encryption
FLASK_SECRET_KEY=change-this-to-any-random-string

# -------------------------------------------
# EMAIL VIA SMTP (Required)
# -------------------------------------------
# SMTP server settings for sending emails
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=no-reply@yourdomain.com
SMTP_PASSWORD=your-smtp-password

# The "From" address shown in emails
EMAIL_FROM=no-reply@pandata.de

# -------------------------------------------
# MIRO INTEGRATION (Optional)
# -------------------------------------------
# Create API token at: https://miro.com/app/settings/user-profile/apps
# Team ID is in URL when you view team settings: https://miro.com/app/settings/team/{TEAM_ID}/
MIRO_ACCESS_TOKEN=your-miro-access-token
MIRO_TEAM_ID=your-team-id

# -------------------------------------------
# GOOGLE DRIVE (Optional)
# -------------------------------------------
# Only needed if you want auto-created Drive folders
# See docs/GOOGLE_INTEGRATION.md for setup instructions
